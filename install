#!/bin/bash
set -euo pipefail
IFS=$'\n\t'
source ./helpers.sh

brew-install stow
brew-install mas
brew-install mise
add-line-to-file ~/.zshrc 'eval "$(/opt/homebrew/bin/mise activate zsh)"'
add-line-to-file ~/.zprofile 'eval "$(mise activate zsh --shims)"'

# ruby dependencies
brew-install openssl@3
brew-install readline
brew-install libyaml
brew-install gmp

brew-install starship
brew-install-cask font-fira-code-nerd-font
brew-install font-fira-code
add-line-to-file ~/.zshrc 'eval "$(starship init zsh)"'

brew-install gnupg

brew-install-cask discord
brew-install-cask slack
brew-install-cask visual-studio-code
brew-install-cask obsidian
brew-install-cask microsoft-teams
brew-install-cask docker
brew-install-cask pinta

brew-install-cask postgres-unofficial
add-line-to-file ~/.zprofile 'export PATH=$PATH:/Applications/Postgres.app/Contents/Versions/latest/bin'

# Home Assistant
mas install 1099568401
# Xcode
mas install 497799835
# Unsplash Wallpapers
mas install 1284863847

mkdir -p ~/.config

stow mise
stow git
stow starship

mise install
